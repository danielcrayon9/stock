GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEET_ID=

# Market data
MARKET_DATA_PROVIDER=yahoo
USE_SAMPLE_MARKET_DATA=false
BROKER_PROVIDER=

# Read-only safety (반드시 유지)
KIS_MODE=real
ENABLE_ORDER=false
READ_ONLY_MODE=true

# Korea Investment & Securities read-only REST API
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_BASE_URL=https://openapi.koreainvestment.com:9443
# KIS_APPROVAL_KEY: WebSocket 실시간 체결/호가 단계에서 사용 (이번 REST 조회 단계에서는 불필요)
KIS_APPROVAL_KEY=
# KIS_ACCOUNT_NO: 주문/계좌 조회용 — 이번 조회 전용 단계에서는 사용하지 않음
KIS_ACCOUNT_NO=

# Kiwoom read-only API placeholder
KIWOOM_APP_KEY=

# Realtime worker / cache (다음 단계)
REALTIME_WORKER_URL=
WORKER_API_SECRET=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# OpenDART
OPENDART_API_KEY=

# Naver Search API
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# AI
OPENAI_API_KEY=
OPENAI_MODEL=
GEMINI_API_KEY=
GEMINI_MODEL=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Vercel Cron 보호용 (선택). 설정 시 /api/scanner/cron 호출에 Authorization: Bearer <값> 필요
